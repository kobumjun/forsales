# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# Auth (for session/cookie)
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth (Supabase Auth uses these)
# Configure in Supabase Dashboard > Authentication > Providers > Google
# Or if using separate NextAuth:
GOOGLE_CLIENT_ID=[YOUR_GOOGLE_CLIENT_ID]
GOOGLE_CLIENT_SECRET=[YOUR_GOOGLE_CLIENT_SECRET]

# OCR API (e.g. Google Vision, Tesseract via API, OCR.space, etc.)
OCR_API_URL=https://vision.googleapis.com/v1/images:annotate
OCR_API_KEY=[YOUR_OCR_API_KEY]

# AI API (e.g. OpenAI, Anthropic, etc.)
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=[YOUR_AI_API_KEY]
AI_MODEL_NAME=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
